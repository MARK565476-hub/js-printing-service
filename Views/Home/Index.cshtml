<script>
    const dragDropArea = document.getElementById('dragDropArea');
    const fileInput = document.getElementById('imageFiles');
    const fileList = document.getElementById('fileList');
    const processingSection = document.getElementById('processingSection');
    const previewContainer = document.getElementById('previewContainer');
    const progressContainer = document.getElementById('progressContainer');
    const previewImage = document.getElementById('previewImage');
    const previewBtn = document.getElementById('previewBtn');
    const statusText = document.getElementById('statusText');

    let selectedFiles = [];
    let fullImageData = null;

    // ===== DRAG & DROP =====
    dragDropArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        dragDropArea.classList.add('drag-over');
    });

    dragDropArea.addEventListener('dragleave', () => {
        dragDropArea.classList.remove('drag-over');
    });

    dragDropArea.addEventListener('drop', (e) => {
        e.preventDefault();
        dragDropArea.classList.remove('drag-over');
        fileInput.files = e.dataTransfer.files;
        handleFileSelection();
    });

    fileInput.addEventListener('change', handleFileSelection);

    // ===== FILE SELECTION HANDLER =====
    function handleFileSelection() {
        selectedFiles = Array.from(fileInput.files);
        fileList.innerHTML = '';

        if (selectedFiles.length === 0) {
            processingSection.style.display = 'none';
            previewContainer.classList.remove('show');
            return;
        }

        if (selectedFiles.length < 1 || selectedFiles.length > 2) {
            addFileItem('⚠️', `Upload 1 image (combined) or 2 images (front & back). You selected ${selectedFiles.length}.`, 'error');
            processingSection.style.display = 'none';
            return;
        }

        if (selectedFiles.length === 1) {
            addFileItem('📸', `Combined: ${selectedFiles[0].name} (${formatFileSize(selectedFiles[0].size)})`, 'success');
            addFileItem('ℹ️', 'System will auto-detect and split into front & back', 'info');
        } else {
            selectedFiles.forEach((file, index) => {
                const icon = index === 0 ? '🆔' : '🔄';
                const label = index === 0 ? 'Front' : 'Back';
                addFileItem(icon, `${label}: ${file.name} (${formatFileSize(file.size)})`, 'success');
            });
        }

        processingSection.style.display = 'block';
        previewContainer.classList.remove('show');
    }

    function addFileItem(icon, text, className) {
        const item = document.createElement('div');
        item.className = `file-item ${className}`;
        const position = selectedFiles.length === 1 ? '(LEFT SIDE)' : '(RIGHT SIDE)';
        item.innerHTML = `
            <div>
                <div style="margin-bottom: 5px;">${icon} ${text}</div>
                <small style="color: #7a7a7a;">→ Will appear on ${position}</small>
            </div>
        `;
        fileList.appendChild(item);
    }

    // ===== FILE SIZE FORMATTER =====
    function formatFileSize(bytes) {
        if (bytes === 0) return '0 Bytes';
        const k = 1024;
        const sizes = ['Bytes', 'KB', 'MB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
    }

    // ===== GENERATE PREVIEW =====
    async function generatePreview() {
        if (selectedFiles.length < 1 || selectedFiles.length > 2) {
            alert('Upload 1 image (combined) or 2 images (front & back)');
            return;
        }

        previewBtn.disabled = true;
        progressContainer.classList.add('show');
        statusText.textContent = '✨ Enhancing and composing layout...';

        try {
            const formData = new FormData();
            formData.append('model.ImageFiles', selectedFiles[0]);

            if (selectedFiles.length === 2) {
                formData.append('model.ImageFiles', selectedFiles[1]);
            }

            const response = await fetch('@Url.Action("PreviewAadhaarPdf", "Home")', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.error || 'Failed to generate preview');
            }

            // Show preview
            previewImage.src = 'data:image/jpeg;base64,' + data.preview;
            fullImageData = data.full;

            progressContainer.classList.remove('show');
            previewContainer.classList.add('show');
            statusText.textContent = '✨ Enhancing and composing layout...';

            // Trigger particle burst effect on success
            createParticleBurst(previewImage.getBoundingClientRect().left + previewImage.offsetWidth / 2,
                              previewImage.getBoundingClientRect().top + previewImage.offsetHeight / 2);

            // Trigger energy ripple from container
            createEnergyRipple();

        } catch (error) {
            progressContainer.classList.remove('show');
            alert('❌ Error: ' + error.message);
            console.error(error);
        } finally {
            previewBtn.disabled = false;
        }
    }

    // ===== DOWNLOAD JPEG =====
    async function downloadJpeg() {
        if (!fullImageData) {
            alert('Please generate preview first');
            return;
        }

        try {
            const byteCharacters = atob(fullImageData);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: 'image/jpeg' });

            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `aadhaar_${new Date().toISOString().slice(0, 10)}.jpg`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);

        } catch (error) {
            alert('❌ Error downloading: ' + error.message);
        }
     }

    // ===== OPEN PREVIEW IN NEW TAB =====
    function openPreviewInNewTab() {
        if (!fullImageData) {
            alert('Please generate preview first');
            return;
        }

        try {
            const byteCharacters = atob(fullImageData);
            const byteNumbers = new Array(byteCharacters.length);
            for (let i = 0; i < byteCharacters.length; i++) {
                byteNumbers[i] = byteCharacters.charCodeAt(i);
            }
            const byteArray = new Uint8Array(byteNumbers);
            const blob = new Blob([byteArray], { type: 'image/jpeg' });

            const url = URL.createObjectURL(blob);
            const newTab = window.open(url);

            if (newTab) {
                newTab.focus();
            } else {
                alert('⚠️ Pop-up blocked. Please enable pop-ups for this site.');
            }

        } catch (error) {
            alert('❌ Error opening preview: ' + error.message);
        }
    }

     // ===== RESET FORM =====
    function resetForm() {
        fileInput.value = '';
        selectedFiles = [];
        fullImageData = null;
        fileList.innerHTML = '';
        processingSection.style.display = 'none';
        previewContainer.classList.remove('show');
        progressContainer.classList.remove('show');
        dragDropArea.classList.remove('drag-over');
    }

    // ===== ADVANCED CURSOR GLOW SYSTEM (60FPS) =====
    class CursorGlowSystem {
        constructor() {
            this.cursorGlow = document.getElementById('cursorGlow');
            if (!this.cursorGlow) {
                this.cursorGlow = document.createElement('div');
                this.cursorGlow.id = 'cursorGlow';
                this.cursorGlow.classList.add('active');
                document.body.appendChild(this.cursorGlow);
            }

            this.mouseX = 0;
            this.mouseY = 0;
            this.glowX = 0;
            this.glowY = 0;
            this.isActive = false;
            this.trailDelay = 0;
            this.trailInterval = 4; // Create trail every 4 frames for smoothness
            this.maxTrails = 8;
            this.trails = [];

            this.bindEvents();
            this.startAnimation();
        }

        bindEvents() {
            document.addEventListener('mousemove', (e) => {
                this.mouseX = e.clientX;
                this.mouseY = e.clientY;
                if (!this.isActive) {
                    this.isActive = true;
                    this.cursorGlow.style.opacity = '0.7';
                }
            });

            document.addEventListener('mouseenter', () => {
                this.isActive = true;
                this.cursorGlow.style.opacity = '0.7';
            });

            document.addEventListener('mouseleave', () => {
                this.isActive = false;
                this.cursorGlow.style.opacity = '0';
            });

            document.addEventListener('click', (e) => {
                this.createClickBurst(e.clientX, e.clientY);
            });

            // Hover effects on interactive elements
            document.addEventListener('mouseover', (e) => {
                if (e.target.classList.contains('btn-neon') || 
                    e.target.classList.contains('drag-drop-area') ||
                    e.target.classList.contains('preview-image')) {
                    this.intensifyGlow();
                }
            });

            document.addEventListener('mouseout', (e) => {
                if (e.target.classList.contains('btn-neon') || 
                    e.target.classList.contains('drag-drop-area') ||
                    e.target.classList.contains('preview-image')) {
                    this.normalizeGlow();
                }
            });
        }

        startAnimation() {
            const animate = () => {
                // Smooth interpolation (lerp) for cinematic trailing
                const lerpFactor = 0.12; // Adjust for trail smoothness
                this.glowX += (this.mouseX - this.glowX) * lerpFactor;
                this.glowY += (this.mouseY - this.glowY) * lerpFactor;

                // Update glow position using left/top for stable centering
                this.cursorGlow.style.left = this.glowX + 'px';
                this.cursorGlow.style.top = this.glowY + 'px';
                this.cursorGlow.style.transform = 'translate(-50%, -50%) scale(0.8)';

                // Create trail particles
                if (this.isActive && this.trailDelay % this.trailInterval === 0) {
                    this.createTrail(this.glowX, this.glowY);
                }

                this.trailDelay++;
                if (this.trailDelay > 1000) this.trailDelay = 0;

                requestAnimationFrame(animate);
            };

            requestAnimationFrame(animate);
        }

        createTrail(x, y) {
            if (this.trails.length >= this.maxTrails) {
                const oldTrail = this.trails.shift();
                oldTrail.remove();
            }

            const trail = document.createElement('div');
            trail.className = 'cursor-trail';

            const size = 40 + Math.random() * 30;
            trail.style.width = size + 'px';
            trail.style.height = size + 'px';
            trail.style.left = (x - size / 2) + 'px';
            trail.style.top = (y - size / 2) + 'px';
            trail.style.animation = `trailFade 0.8s ease-out forwards`;

            document.body.appendChild(trail);
            this.trails.push(trail);

            // Auto-remove after fade
            setTimeout(() => {
                trail.remove();
                this.trails = this.trails.filter(t => t !== trail);
            }, 800);
        }

        createClickBurst(x, y) {
            const burst = document.createElement('div');
            burst.style.position = 'fixed';
            burst.style.left = x + 'px';
            burst.style.top = y + 'px';
            burst.style.width = '100px';
            burst.style.height = '100px';
            burst.style.borderRadius = '50%';
            burst.style.background = 'radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.3) 30%, transparent 100%)';
            burst.style.filter = 'blur(30px)';
            burst.style.mixBlendMode = 'screen';
            burst.style.pointerEvents = 'none';
            burst.style.zIndex = '9999';
            burst.style.animation = `clickBurst 0.6s ease-out forwards`;

            document.body.appendChild(burst);

            setTimeout(() => burst.remove(), 600);
        }

        intensifyGlow() {
            this.cursorGlow.style.opacity = '1';
            this.cursorGlow.style.filter = 'blur(35px)';
            this.cursorGlow.style.boxShadow = `
                0 0 30px rgba(255, 255, 255, 0.9),
                0 0 60px rgba(255, 255, 255, 0.5),
                inset 0 0 30px rgba(255, 255, 255, 0.4)
            `;
        }

        normalizeGlow() {
            this.cursorGlow.style.opacity = '0.7';
            this.cursorGlow.style.filter = 'blur(25px)';
            this.cursorGlow.style.boxShadow = `
                0 0 20px rgba(255, 255, 255, 0.6),
                0 0 40px rgba(255, 255, 255, 0.3),
                inset 0 0 20px rgba(255, 255, 255, 0.2)
            `;
        }
    }

    // Initialize cursor glow system when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
            new CursorGlowSystem();
            initializeAdvancedEffects();
        });
    } else {
        new CursorGlowSystem();
        initializeAdvancedEffects();
    }

    // ===== ADVANCED EFFECTS SYSTEM =====

    // Energy ripple from container
    function createEnergyRipple() {
        const container = document.querySelector('.cyber-container');
        const rect = container.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;

        const ripple = document.createElement('div');
        ripple.className = 'energy-ripple';
        ripple.style.left = centerX + 'px';
        ripple.style.top = centerY + 'px';
        ripple.style.animation = 'energyRipple 0.8s ease-out forwards';

        document.body.appendChild(ripple);

        setTimeout(() => ripple.remove(), 800);
    }

    // Particle burst on success
    function createParticleBurst(x, y) {
        const particleCount = 12;
        for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle-burst';

            const size = 8 + Math.random() * 12;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            particle.style.left = x + 'px';
            particle.style.top = y + 'px';

            const angle = (i / particleCount) * Math.PI * 2;
            const velocity = 100 + Math.random() * 150;
            const tx = Math.cos(angle) * velocity;
            const ty = Math.sin(angle) * velocity;

            particle.style.setProperty('--tx', tx + 'px');
            particle.style.background = `radial-gradient(circle, rgba(0, 255, 255, 0.9) 0%, rgba(0, 255, 255, 0.4) 70%, transparent 100%)`;
            particle.style.filter = 'blur(3px)';
            particle.style.boxShadow = '0 0 10px rgba(0, 255, 255, 0.8)';
            particle.style.animation = `particleFall ${0.8 + Math.random() * 0.4}s ease-out forwards`;

            document.body.appendChild(particle);

            setTimeout(() => particle.remove(), 1200);
        }
    }

    // Theme management system
    function initializeAdvancedEffects() {
        const themeToggle = document.getElementById('themeToggle');
        const themes = ['cyan', 'matrix', 'danger', 'purple'];
        let currentThemeIndex = 0;

        // Load saved theme from localStorage
        const savedTheme = localStorage.getItem('appTheme') || 'cyan';
        applyTheme(savedTheme);

        themeToggle.addEventListener('click', () => {
            currentThemeIndex = (currentThemeIndex + 1) % themes.length;
            const newTheme = themes[currentThemeIndex];
            applyTheme(newTheme);
            localStorage.setItem('appTheme', newTheme);

            // Visual feedback
            createEnergyRipple();
        });
    }

    function applyTheme(theme) {
        document.body.classList.remove('theme-matrix', 'theme-danger', 'theme-purple');

        const themeColors = {
            cyan: {
                primary: '#00ffff',
                secondary: '#ff00ff',
                accent: '#00ff41'
            },
            matrix: {
                primary: '#00ff41',
                secondary: '#0f0',
                accent: '#00ff00'
            },
            danger: {
                primary: '#ff1744',
                secondary: '#ff6b6b',
                accent: '#ff1744'
            },
            purple: {
                primary: '#9c27b0',
                secondary: '#ce93d8',
                accent: '#ba68c8'
            }
        };

        const colors = themeColors[theme];
        document.documentElement.style.setProperty('--primary-color', colors.primary);
        document.documentElement.style.setProperty('--secondary-color', colors.secondary);
        document.documentElement.style.setProperty('--accent-color', colors.accent);

        if (theme !== 'cyan') {
            document.body.classList.add(`theme-${theme}`);
        }

        // Update all color-dependent elements
        updateThemeColors(colors);
    }

    function updateThemeColors(colors) {
        // Update cyber container border
        const container = document.querySelector('.cyber-container');
        if (container) {
            container.style.borderColor = colors.primary;
        }

        // Update buttons
        document.querySelectorAll('.btn-neon').forEach(btn => {
            if (btn.classList.contains('primary')) {
                btn.style.borderColor = colors.secondary;
                btn.style.color = colors.secondary;
            } else if (btn.classList.contains('success')) {
                btn.style.borderColor = colors.accent;
                btn.style.color = colors.accent;
            } else {
                btn.style.borderColor = colors.primary;
                btn.style.color = colors.primary;
            }
        });

        // Update drag-drop area
        const dragArea = document.getElementById('dragDropArea');
        if (dragArea) {
            dragArea.style.borderColor = colors.primary;
        }
    }

    // Energy pulse on button actions
    document.querySelectorAll('.btn-neon').forEach(btn => {
        btn.addEventListener('click', function() {
            createEnergyRipple();
        });
    });
</script>
