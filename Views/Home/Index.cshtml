@model UploadViewModel

@{
    ViewData["Title"] = "Aadhaar Card Processor - AI-Powered Enhancement";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0f0f23 100%);
        background-attachment: fixed;
        backdrop-filter: blur(80px);
        color: #e0e0e0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
        padding-bottom: 50px;
        position: relative;
        overflow-x: hidden;
    }

    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, 
            rgba(0, 255, 255, 0.03) 0%, 
            rgba(255, 0, 255, 0.03) 50%, 
            rgba(0, 255, 255, 0.03) 100%);
        pointer-events: none;
        z-index: 1;
        animation: bgShimmer 8s ease-in-out infinite;
    }

    /* Falling Water Droplets - Enhanced Glow */
    body::after {
        content: '';
        position: fixed;
        top: -50px;
        left: 0;
        width: 100%;
        height: 200px;
        background-image: 
            radial-gradient(circle 3px at 20% 10%, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.4) 40%, transparent 100%),
            radial-gradient(circle 3px at 40% 30%, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.3) 40%, transparent 100%),
            radial-gradient(circle 3px at 60% 50%, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.35) 40%, transparent 100%),
            radial-gradient(circle 3px at 80% 20%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.25) 40%, transparent 100%),
            radial-gradient(circle 3px at 10% 40%, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0.45) 40%, transparent 100%),
            radial-gradient(circle 3px at 50% 70%, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.3) 40%, transparent 100%),
            radial-gradient(circle 3px at 30% 60%, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.35) 40%, transparent 100%),
            radial-gradient(circle 3px at 70% 40%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.25) 40%, transparent 100%),
            radial-gradient(circle 3px at 90% 60%, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.4) 40%, transparent 100%),
            radial-gradient(circle 3px at 15% 70%, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.3) 40%, transparent 100%);
        background-size: 100% 100%;
        background-repeat: repeat-y;
        filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.8)) drop-shadow(0 0 25px rgba(255, 255, 255, 0.4)) blur(1px);
        pointer-events: none;
        z-index: 1;
        animation: dropletFall 15s linear infinite, rainGlowPulse 3s ease-in-out infinite;
    }

    /* Cursor Glow Element */
    #cursorGlow {
        position: fixed;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9998;
        opacity: 0;
        will-change: transform, opacity;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.4) 20%, rgba(255, 255, 255, 0.1) 50%, transparent 100%);
        filter: blur(25px);
        mix-blend-mode: screen;
        box-shadow: 
            0 0 20px rgba(255, 255, 255, 0.6),
            0 0 40px rgba(255, 255, 255, 0.3),
            inset 0 0 20px rgba(255, 255, 255, 0.2);
        transform: translate(-50%, -50%) scale(0.8);
    }

    #cursorGlow.active {
        animation: glowPulse 1.5s ease-in-out infinite;
    }

    /* Cursor Trail */
    .cursor-trail {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9997;
        will-change: transform, opacity;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.2) 30%, transparent 100%);
        filter: blur(20px);
        mix-blend-mode: screen;
        box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
    }

    /* ===== DEPTH FOG LAYER ===== */
    #depthFog {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(ellipse at 50% 50%, rgba(0, 255, 255, 0.02) 0%, rgba(0, 255, 255, 0.08) 100%);
        pointer-events: none;
        z-index: 2;
        animation: fogDrift 20s ease-in-out infinite;
    }

    /* ===== ENERGY RIPPLE CONTAINER ===== */
    .energy-ripple {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 3000;
        border: 2px solid var(--primary-color, #00ffff);
        opacity: 0;
    }

    /* ===== PARTICLE BURST ===== */
    .particle-burst {
        position: fixed;
        pointer-events: none;
        z-index: 9996;
        will-change: transform, opacity;
        border-radius: 50%;
    }

    /* ===== THEME TOGGLE BUTTON ===== */
    #themeToggle {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: 2px solid var(--primary-color, #00ffff);
        background: rgba(10, 10, 10, 0.8);
        color: var(--primary-color, #00ffff);
        font-size: 1.5rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
        animation: buttonGlowPulse 3s ease-in-out infinite;
    }

    #themeToggle:hover {
        transform: scale(1.1);
        box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
    }

    /* ===== LIQUID GLASS BUTTON HIGHLIGHT ===== */
    .btn-neon::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, 
            transparent 0%, 
            rgba(255, 255, 255, 0.3) 50%, 
            transparent 100%);
        animation: liquidGloss 3s infinite;
        pointer-events: none;
        border-radius: 4px;
    }

    /* ===== PROFESSIONAL THEME SYSTEM ===== */
    :root {
        /* Design Tokens - Cyber Default */
        --color-bg-primary: #0a0a0a;
        --color-bg-secondary: #1a1a2e;
        --color-accent-primary: #00ffff;
        --color-accent-secondary: #ff00ff;
        --color-glow-primary: rgba(0, 255, 255, 0.5);
        --color-glow-secondary: rgba(0, 255, 255, 0.2);
        --color-text-primary: #e0e0e0;
        --color-text-secondary: #b0b0b0;
        --color-text-muted: #7a7a7a;
        --color-border: #00ffff;
        --color-danger: #ff1744;
        --color-success: #00ff41;
        --color-warning: #ff00ff;
        --transition-duration: 0.4s;
        --glow-intensity: 1;
    }

    /* Theme: Cyber (Default) */
    body.theme-cyber {
        --color-accent-primary: #00ffff;
        --color-accent-secondary: #ff00ff;
        --color-success: #00ff41;
        --color-glow-primary: rgba(0, 255, 255, 0.5);
        --color-glow-secondary: rgba(0, 255, 255, 0.2);
        --color-border: #00ffff;
    }

    /* Theme: Matrix */
    body.theme-matrix {
        --color-accent-primary: #00ff41;
        --color-accent-secondary: #0f0;
        --color-success: #00ff00;
        --color-glow-primary: rgba(0, 255, 65, 0.5);
        --color-glow-secondary: rgba(0, 255, 65, 0.2);
        --color-border: #00ff41;
    }

    /* Theme: Danger */
    body.theme-danger {
        --color-accent-primary: #ff1744;
        --color-accent-secondary: #ff6b6b;
        --color-success: #ff1744;
        --color-glow-primary: rgba(255, 23, 68, 0.5);
        --color-glow-secondary: rgba(255, 23, 68, 0.2);
        --color-border: #ff1744;
    }

    /* Theme: Purple */
    body.theme-purple {
        --color-accent-primary: #9c27b0;
        --color-accent-secondary: #ce93d8;
        --color-success: #ba68c8;
        --color-glow-primary: rgba(156, 39, 176, 0.5);
        --color-glow-secondary: rgba(156, 39, 176, 0.2);
        --color-border: #9c27b0;
    }

    /* Theme: Ice */
    body.theme-ice {
        --color-accent-primary: #e0f7ff;
        --color-accent-secondary: #80deea;
        --color-success: #4dd0e1;
        --color-glow-primary: rgba(224, 247, 255, 0.4);
        --color-glow-secondary: rgba(224, 247, 255, 0.15);
        --color-border: #80deea;
    }

    /* Global transition rule */
    * {
        transition: background-color var(--transition-duration) ease, 
                    color var(--transition-duration) ease,
                    border-color var(--transition-duration) ease,
                    box-shadow var(--transition-duration) ease,
                    text-shadow var(--transition-duration) ease !important;
    }

    .main-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }

    .cyber-container {
        background: rgba(10, 10, 10, 0.7);
        border: 2px solid #00ffff;
        border-radius: 8px;
        box-shadow: 0 0 30px rgba(0, 255, 255, 0.3), inset 0 0 20px rgba(0, 255, 255, 0.1);
        padding: 40px;
        margin-top: 40px;
        backdrop-filter: blur(10px);
        animation: borderPulse 3s ease-in-out infinite, containerGlowWave 8s ease-in-out infinite, containerBreathe 6s ease-in-out infinite;
    }

    .cyber-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 2.5rem;
        font-weight: 900;
        background: linear-gradient(45deg, #00ffff, #ff00ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 20px rgba(0, 255, 255, 0.5);
        margin-bottom: 10px;
        animation: titleGlow 4s ease-in-out infinite, titleWave 8s ease-in-out infinite;
    }

    .cyber-subtitle {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.1rem;
        color: #ff00ff;
        margin-bottom: 30px;
        animation: subtitlePulse 3s ease-in-out infinite, subtitleGlow 6s ease-in-out infinite;
    }

    .drag-drop-area {
        border: 3px dashed #00ffff;
        border-radius: 8px;
        padding: 50px 20px;
        text-align: center;
        cursor: pointer;
        background: linear-gradient(135deg, rgba(0, 255, 255, 0.05) 0%, rgba(255, 0, 255, 0.05) 100%);
        transition: all 0.3s ease;
        position: relative;
        animation: dragAreaPulse 4s ease-in-out infinite, dragAreaGlow 6s ease-in-out infinite;
    }

    .drag-drop-area:hover {
        border-color: #ff00ff;
        box-shadow: 0 0 20px rgba(255, 0, 255, 0.3);
    }

    .drag-drop-area.drag-over {
        border-color: #00ff41;
        background: linear-gradient(135deg, rgba(0, 255, 65, 0.15) 0%, rgba(0, 255, 65, 0.15) 100%);
        box-shadow: 0 0 30px rgba(0, 255, 65, 0.4);
    }

    .drag-drop-icon {
        font-size: 3rem;
        color: #00ffff;
        margin-bottom: 15px;
        animation: iconBounce 2s ease-in-out infinite, iconRotate 6s linear infinite, iconPulse 4s ease-in-out infinite;
        display: inline-block;
    }

    .drag-drop-text {
        font-size: 1.2rem;
        color: #00ffff;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .drag-drop-hint {
        color: #7a7a7a;
        font-size: 0.9rem;
    }

    .file-input {
        display: none;
    }

    .file-list {
        margin-top: 20px;
        display: grid;
        gap: 10px;
    }

    .file-item {
        background: rgba(0, 255, 255, 0.1);
        border-left: 4px solid #00ffff;
        padding: 12px;
        border-radius: 4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        animation: slideIn 0.3s ease, fileItemShimmer 6s ease-in-out infinite, fileItemHighlight 4s ease-in-out infinite;
        transition: all 0.3s ease;
    }

    .file-item:hover {
        animation: fileItemHover 0.5s ease forwards, fileItemShimmer 6s ease-in-out infinite;
        transform: translateX(5px);
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.4);
    }

    .file-item.success {
        border-left-color: #00ff41;
        background: rgba(0, 255, 65, 0.1);
    }

    .file-item.error {
        border-left-color: #ff1744;
        background: rgba(255, 23, 68, 0.1);
    }

    .file-item.info {
        border-left-color: #00ffff;
        background: rgba(0, 255, 255, 0.05);
        color: #00ffff;
    }

    .file-name {
        color: #e0e0e0;
    }

    .file-size {
        color: #7a7a7a;
        font-size: 0.85rem;
    }

    .btn-neon {
        font-family: 'Orbitron', sans-serif;
        font-weight: 700;
        border: 2px solid #00ffff;
        background: transparent;
        color: #00ffff;
        padding: 12px 30px;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
        box-shadow: 0 0 10px rgba(0, 255, 255, 0.3);
        margin: 5px;
        font-size: 1rem;
        animation: buttonGlowPulse 3s ease-in-out infinite;
        position: relative;
        overflow: hidden;
    }

    .btn-neon::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        animation: buttonShimmer 3s infinite;
    }

    .btn-neon:hover {
        background: #00ffff;
        color: #0a0a0a;
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.7), 0 0 40px rgba(0, 255, 255, 0.5);
        transform: scale(1.05) translateY(-3px);
        animation: buttonHoverGlow 0.6s ease forwards;
    }

    .btn-neon.primary {
        border-color: #ff00ff;
        color: #ff00ff;
        box-shadow: 0 0 10px rgba(255, 0, 255, 0.3);
        animation: buttonGlowPulse 3s ease-in-out infinite, primaryPulse 4s ease-in-out infinite;
    }

    .btn-neon.primary:hover {
        background: #ff00ff;
        color: #0a0a0a;
        box-shadow: 0 0 20px rgba(255, 0, 255, 0.7), 0 0 40px rgba(255, 0, 255, 0.5);
        animation: primaryHoverGlow 0.6s ease forwards;
    }

    .btn-neon.success {
        border-color: #00ff41;
        color: #00ff41;
        box-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
        animation: buttonGlowPulse 3s ease-in-out infinite, successPulse 4s ease-in-out infinite;
    }

    .btn-neon.success:hover {
        background: #00ff41;
        color: #0a0a0a;
        box-shadow: 0 0 20px rgba(0, 255, 65, 0.7), 0 0 40px rgba(0, 255, 65, 0.5);
        animation: successHoverGlow 0.6s ease forwards;
    }

    .btn-neon:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        box-shadow: none;
    }

    .button-group {
        display: flex;
        gap: 10px;
        margin-top: 30px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .progress-container {
        display: none;
        margin-top: 30px;
        text-align: center;
    }

    .progress-container.show {
        display: block;
        animation: slideIn 0.3s ease;
    }

    .spinner {
        display: inline-block;
        width: 30px;
        height: 30px;
        border: 3px solid rgba(0, 255, 255, 0.3);
        border-top: 3px solid #00ffff;
        border-radius: 50%;
        animation: spin 1s linear infinite, spinnerGlow 2s ease-in-out infinite, spinnerColorCycle 4s ease-in-out infinite;
        margin-right: 10px;
        box-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
    }

    .status-text {
        color: #00ffff;
        font-weight: 600;
        margin-top: 10px;
    }

    .progress-bar-cyber {
        height: 4px;
        background: linear-gradient(90deg, #00ffff, #ff00ff, #00ffff);
        border-radius: 2px;
        overflow: hidden;
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.5);
        margin-top: 15px;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #00ffff, #ff00ff);
        width: 0%;
        animation: progress 2s ease-in-out infinite, progressWave 4s ease-in-out infinite, progressGlow 3s ease-in-out infinite;
    }

    .preview-container {
        display: none;
        margin-top: 30px;
        padding: 20px;
        background: rgba(0, 255, 255, 0.05);
        border: 2px solid #00ffff;
        border-radius: 8px;
        animation: previewFloat 8s ease-in-out infinite;
    }

    .preview-container.show {
        display: block;
        animation: slideIn 0.3s ease, previewFloat 8s ease-in-out infinite, previewGlow 6s ease-in-out infinite;
    }

    .preview-title {
        font-family: 'Orbitron', sans-serif;
        color: #00ffff;
        font-weight: 700;
        margin-bottom: 20px;
        text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
    }

    .preview-image {
        max-width: 100%;
        height: auto;
        border: 2px solid #00ffff;
        border-radius: 4px;
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
        margin-bottom: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        animation: imageBreathing 6s ease-in-out infinite;
    }

    .preview-image:hover {
        box-shadow: 0 0 30px rgba(0, 255, 255, 0.6), 0 0 50px rgba(255, 0, 255, 0.3);
        transform: scale(1.02);
        border-color: #ff00ff;
        animation: imageHoverGlow 0.5s ease forwards, imageBreathing 6s ease-in-out infinite;
    }

    .download-button-group {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .alert-error {
        background: rgba(255, 23, 68, 0.15);
        border: 2px solid #ff1744;
        border-radius: 4px;
        padding: 15px;
        color: #ff6b6b;
        margin-bottom: 20px;
        animation: alertSlideIn 0.4s ease, alertPulse 2s ease-in-out infinite;
    }

    .alert-success {
        background: rgba(0, 255, 65, 0.15);
        border: 2px solid #00ff41;
        border-radius: 4px;
        padding: 15px;
        color: #00ff41;
        margin-bottom: 20px;
        animation: alertSlideIn 0.4s ease, alertSuccessPulse 2s ease-in-out infinite;
    }

    .info-box {
        background: linear-gradient(135deg, rgba(0, 255, 255, 0.1) 0%, rgba(255, 0, 255, 0.1) 100%);
        border-left: 4px solid #00ffff;
        border-radius: 4px;
        padding: 20px;
        margin-top: 30px;
        color: #b0b0b0;
        animation: infoBoxGradientShift 8s ease-in-out infinite, infoBoxPulse 4s ease-in-out infinite;
    }

    .info-title {
        font-family: 'Orbitron', sans-serif;
        color: #00ffff;
        font-weight: 700;
        margin-bottom: 15px;
        text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
    }

    @@keyframes borderPulse {
        0%, 100% { box-shadow: 0 0 30px rgba(0, 255, 255, 0.3), inset 0 0 20px rgba(0, 255, 255, 0.1); }
        50% { box-shadow: 0 0 50px rgba(0, 255, 255, 0.5), inset 0 0 30px rgba(0, 255, 255, 0.2); }
    }

    @@keyframes slideIn {
        from { transform: translateY(-20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes progress {
        0%, 100% { width: 0%; }
        50% { width: 100%; }
    }

    /* ===== NEW ANIMATIONS ===== */

    @@keyframes bgShimmer {
        0%, 100% { opacity: 0.03; }
        50% { opacity: 0.08; }
    }

    @@keyframes dropletFall {
        0% { transform: translateY(-50px); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { transform: translateY(100vh); opacity: 0; }
    }

    @@keyframes titleGlow {
        0%, 100% { text-shadow: 0 0 20px rgba(0, 255, 255, 0.5), 0 0 30px rgba(255, 0, 255, 0.3); }
        50% { text-shadow: 0 0 40px rgba(0, 255, 255, 0.8), 0 0 60px rgba(255, 0, 255, 0.6); }
    }

    @@keyframes titleWave {
        0%, 100% { letter-spacing: 0px; }
        50% { letter-spacing: 2px; }
    }

    @@keyframes subtitlePulse {
        0%, 100% { opacity: 0.7; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.05); }
    }

    @@keyframes subtitleGlow {
        0%, 100% { text-shadow: 0 0 10px rgba(255, 0, 255, 0.5); }
        50% { text-shadow: 0 0 30px rgba(255, 0, 255, 0.9), 0 0 50px rgba(0, 255, 255, 0.5); }
    }

    @@keyframes iconBounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    @@keyframes iconRotate {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @@keyframes iconPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.15); }
    }

    @@keyframes textWave {
        0%, 100% { transform: skewX(0deg); }
        25% { transform: skewX(-2deg); }
        75% { transform: skewX(2deg); }
    }

    @@keyframes textGlow {
        0%, 100% { text-shadow: 0 0 5px rgba(0, 255, 255, 0.5); }
        50% { text-shadow: 0 0 20px rgba(0, 255, 255, 0.9), 0 0 35px rgba(0, 255, 255, 0.6); }
    }

    @@keyframes dragAreaPulse {
        0%, 100% { background: linear-gradient(135deg, rgba(0, 255, 255, 0.05) 0%, rgba(255, 0, 255, 0.05) 100%); }
        50% { background: linear-gradient(135deg, rgba(0, 255, 255, 0.15) 0%, rgba(255, 0, 255, 0.15) 100%); }
    }

    @@keyframes dragAreaGlow {
        0%, 100% { box-shadow: 0 0 10px rgba(0, 255, 255, 0.2); }
        50% { box-shadow: 0 0 30px rgba(0, 255, 255, 0.5), inset 0 0 20px rgba(0, 255, 255, 0.2); }
    }

    @@keyframes fileItemShimmer {
        0%, 100% { background: rgba(0, 255, 255, 0.1); }
        50% { background: rgba(0, 255, 255, 0.2); }
    }

    @@keyframes fileItemHighlight {
        0%, 100% { box-shadow: 0 0 5px rgba(0, 255, 255, 0.2); }
